rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Carousel ads - read for all, write for authenticated users
    match /carousel_ads/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Projects - read for all, write for authenticated users
    match /projects/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Contact info - read for all, write for authenticated users
    match /contact_info/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}